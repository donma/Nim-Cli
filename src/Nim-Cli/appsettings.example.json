{
  "NimCli": {
    "Provider": {
      "Name": "nim",
      "ApiKey": "",
      "BaseUrl": "https://integrate.api.nvidia.com/v1",
      "DefaultModel": "openai/gpt-oss-120b",
      "TimeoutSeconds": 120,
      "Streaming": true,
      "Temperature": 0.2,
      "MaxTokens": 4096
    },
    "Shell": {
      "Default": "powershell",
      "PowershellExe": "pwsh",
      "WorkingDirectory": ""
    },
    "Browser": {
      "Engine": "chromium",
      "Headless": true,
      "DefaultViewportWidth": 1440,
      "DefaultViewportHeight": 900
    },
    "Coding": {
      "EnableRepoMap": true,
      "AutoBuildAfterEdit": true,
      "AutoLint": true,
      "AutoTest": false,
      "AutoCommit": false
    },
    "Tools": {
      "AllowShell": true,
      "AllowWebFetch": true,
      "AllowWebSearch": true,
      "AllowBrowser": true,
      "AllowDbRead": true,
      "AllowFtpUpload": false,
      "AllowGitPush": false
    },
    "Retry": {
      "MaxAttempts": 2,
      "DelayMilliseconds": 1000
    },
    "Mcp": {
      "Enabled": false,
      "Command": "",
      "Arguments": "",
      "WorkingDirectory": ""
    }
  }
}
